# ─────────────────────────────────────────────────────────────────────────────
# Apart Cba · plantilla de variables de entorno
# Copiar a .env.local y completar. NUNCA commitear .env.local (ya está en .gitignore).
# En Vercel: vercel env add <VAR> o desde el dashboard del proyecto.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Supabase ────────────────────────────────────────────────────────────────
# URL del proyecto Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Clave ANON (pública — se bundlea al navegador).
# Obtenerla en: Supabase Dashboard → Project Settings → API → "anon public"
# ⚠️  NO usar aquí la clave service_role: quedaría expuesta en el cliente.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Clave SERVICE_ROLE (solo servidor — bypasea RLS).
# Obtenerla en: Supabase Dashboard → Project Settings → API → "service_role"
# Usar exclusivamente desde Server Components / Server Actions / Route Handlers.
SUPABASE_SERVICE_ROLE_KEY=

# ─── URL pública de la app ───────────────────────────────────────────────────
# En local: http://localhost:3001 · En Vercel: https://<dominio-de-producción>
NEXT_PUBLIC_APP_URL=http://localhost:3001
