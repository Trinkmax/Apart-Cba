{
  "name": "rentos-whatsapp-gateway",
  "version": "1.0.0",
  "private": true,
  "description": "Always-on Baileys gateway for rentOS — holds the persistent WhatsApp Web socket per organization. Deployed on Railway (Vercel cannot host a 24/7 WebSocket).",
  "license": "UNLICENSED",
  "type": "commonjs",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20.18.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "@whiskeysockets/baileys": "^6.7.0",
    "express": "^4.21.2",
    "pino": "^9.5.0",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "@types/qrcode": "^1.5.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
