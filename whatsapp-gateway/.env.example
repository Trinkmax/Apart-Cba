# ─── HTTP server ───────────────────────────────────────────────────────────
PORT=8080

# Shared bearer secret. The Next.js app sends `Authorization: Bearer <this>`
# on every gateway call, and the gateway signs its webhook with the SAME value
# (HMAC-SHA256). Generate: openssl rand -hex 32
GATEWAY_SECRET=

# ─── Supabase (service role — durable Baileys state + media upload) ─────────
# SAME project as the Next.js app. Schema is pinned to `apartcba` in code.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Where to deliver inbound events / connection updates ──────────────────
# The rentOS app webhook. e.g. https://app.apartcba.com/api/webhooks/baileys
APP_WEBHOOK_URL=

# ─── Keystore encryption ───────────────────────────────────────────────────
# 32-byte key (64 hex chars) used to AES-256-GCM encrypt the Baileys keystore
# at rest in crm_baileys_auth_state. LOSING THIS = every org must re-scan QR.
# Generate: openssl rand -hex 32
BAILEYS_STATE_ENC_KEY=

# ─── Tuning (optional, sane defaults) ──────────────────────────────────────
# Min gap between two outbound sends on the same number (ms). Anti-ban pacing.
SEND_MIN_GAP_MS=1200
# Extra random jitter added before each send (ms, 0..this).
SEND_JITTER_MS=1500
# Max reconnect backoff (ms).
RECONNECT_MAX_MS=120000
LOG_LEVEL=info
