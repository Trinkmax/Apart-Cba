# ─── Supabase (existentes) ────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3001

# ─── Vercel cron auth (existente) ─────────────────────────────────────────
CRON_SECRET=

# ─── CRM: pg_cron → /api/cron/from-pg ─────────────────────────────────────
# Generar con: openssl rand -hex 32
# Configurar en Supabase con:
#   ALTER DATABASE postgres SET apartcba.app_url = 'https://app.apart-cba.com';
#   ALTER DATABASE postgres SET apartcba.pg_cron_secret = '<el mismo valor>';
PG_CRON_SECRET=

# ─── CRM: WhatsApp Cloud API ──────────────────────────────────────────────
# Versión Graph API (default v22.0). Sólo override si hace falta.
META_GRAPH_API_VERSION=v22.0
# Token global de verificación de webhook (usado cuando aún no hay canal con
# token propio). Por canal usar webhook_verify_token configurado en /dashboard/crm/config
META_WEBHOOK_DEFAULT_TOKEN=

# ─── CRM: Vercel AI Gateway (opcional) ────────────────────────────────────
# Solo si una org elige chat_provider = 'vercel_gateway'.
# Por default cada org carga su propia key Anthropic/OpenAI desde la UI.
VERCEL_AI_GATEWAY_API_KEY=
