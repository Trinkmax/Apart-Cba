{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "regions": ["gru1"],
  "crons": [
    {
      "path": "/api/cron/sync-ical",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/payment-reminders",
      "schedule": "0 9 * * *"
    }
  ],
  "functions": {
    "src/app/api/cron/sync-ical/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/cron/payment-reminders/route.ts": {
      "maxDuration": 60
    }
  }
}
